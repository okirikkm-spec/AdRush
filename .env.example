# Скопируйте этот файл в ".env" и при необходимости заполните значения.
# docker compose загружает .env автоматически.

# ====== Postgres ======
DB_NAME=adrenrush_db
DB_USER=postgres
DB_PASSWORD=password

# ====== MinIO ======
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_BUCKET=adrenrush-media

# ====== Безопасность ======
JWT_SECRET=adrenrush-super-secret-key-minimum-32-chars-long

# ====== Стартовый администратор (создаётся при первом запуске) ======
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
